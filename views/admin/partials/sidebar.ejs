    <span class="sidebar-label">ADMIN PANEL</span>
  </div>

  <nav class="sidebar-nav">

    <div class="nav-group">
      <span class="nav-group-label">OVERVIEW</span>
      <a href="/admin/dashboard" class="nav-item <%= currentPage === 'dashboard' ? 'active' : '' %>">
