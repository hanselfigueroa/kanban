<%- include('../partials/head', { title: 'Orders - Kanban.UNO Admin' }) %>
</head>
<body class="admin-body">
<div class="admin-wrapper">

  <%- include('../partials/sidebar') %>

  <div class="admin-main">
    <%- include('../partials/topbar', { pageTitle: 'Orders' }) %>

    <div class="admin-content">

      <!-- Stats -->
      <div class="metrics-grid">
        <div class="metric-card metric-card--primary">
          <div class="metric-card__body">
            <div class="metric-card__value"><%= stats.total_orders %></div>
            <div class="metric-card__label">Total Orders</div>
          </div>
        </div>
        <div class="metric-card metric-card--success">
          <div class="metric-card__body">
            <div class="metric-card__value"><%= stats.paid_orders %></div>
            <div class="metric-card__label">Paid</div>
          </div>
        </div>
        <div class="metric-card metric-card--warning">
          <div class="metric-card__body">
            <div class="metric-card__value"><%= stats.pending_orders %></div>
            <div class="metric-card__label">Pending</div>
          </div>
        </div>
        <div class="metric-card metric-card--info">
          <div class="metric-card__body">
            <div class="metric-card__value">GTQ <%= parseFloat(stats.total_revenue).toFixed(2) %></div>
            <div class="metric-card__label">Revenue</div>
          </div>
        </div>
      </div>

      <!-- Filters -->
      <div class="filter-bar">
        <form method="GET" action="/admin/orders" class="filter-bar-form">
          <input type="text" name="search" class="form-input" placeholder="Search orders..."
            value="<%= filters.search %>">
          <select name="status" class="form-select">
            <option value="">All Statuses</option>
            <option value="pending" <%= filters.payment_status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="paid" <%= filters.payment_status === 'paid' ? 'selected' : '' %>>Paid</option>
            <option value="failed" <%= filters.payment_status === 'failed' ? 'selected' : '' %>>Failed</option>
            <option value="refunded" <%= filters.payment_status === 'refunded' ? 'selected' : '' %>>Refunded</option>
          </select>
          <select name="course" class="form-select">
            <option value="">All Courses</option>
            <% courses.forEach(function(c) { %>
              <option value="<%= c.course_id %>" <%= filters.course_id === c.course_id ? 'selected' : '' %>><%= c.acronym %></option>
            <% }); %>
          </select>
          <button type="submit" class="btn btn-secondary"><i class="fas fa-search"></i> Filter</button>
        </form>
      </div>

      <!-- Orders Table -->
      <% if (orders.length > 0) { %>
        <div class="table-card">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Order #</th>
                <th>Customer</th>
                <th>Course</th>
                <th>Total</th>
                <th>Status</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% orders.forEach(function(order) { %>
                <tr>
                  <td><code><%= order.order_number %></code></td>
                  <td>
                    <strong><%= order.customer_name %></strong>
                    <br><small><%= order.customer_email %></small>
                  </td>
                  <td><span class="badge badge-info"><%= order.acronym || order.course_id %></span></td>
                  <td><%= order.currency %> <%= parseFloat(order.total).toFixed(2) %></td>
                  <td>
                    <span class="badge badge-<%= order.payment_status === 'paid' ? 'success' : (order.payment_status === 'failed' ? 'danger' : 'warning') %>">
                      <%= order.payment_status %>
                    </span>
                  </td>
                  <td><%= new Date(order.created_at).toLocaleDateString() %></td>
                  <td>
                    <a href="/admin/orders/<%= order.id %>" class="btn btn-sm btn-secondary">
                      <i class="fas fa-eye"></i> View
                    </a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon"><i class="fas fa-receipt"></i></div>
          <h3 class="empty-state-title">No Orders Yet</h3>
          <p class="empty-state-text">Orders will appear here once customers go through the checkout process.</p>
        </div>
      <% } %>

    </div>
  </div>
</div>

<%- include('../partials/scripts') %>
