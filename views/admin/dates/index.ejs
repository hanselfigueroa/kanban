<%- include('../partials/head', { title: 'Course Dates - Kanban.UNO Admin' }) %>
</head>
<body>
<div class="admin-wrapper">

  <%- include('../partials/sidebar') %>

  <div class="admin-main">
    <%- include('../partials/topbar', { pageTitle: 'Course Dates' }) %>

    <div class="admin-content">

      <div class="content-header">
        <h2 class="content-title">Course Dates</h2>
        <a href="/admin/dates/new" class="btn btn-primary">
          <i class="fas fa-plus"></i>
          Add New Date
        </a>
      </div>

      <!-- Filter Bar -->
      <form method="GET" action="/admin/dates" class="filter-bar">
        <div class="filter-group">
          <label for="filterCourse" class="filter-label">Course</label>
          <select id="filterCourse" name="course" class="form-select form-select-sm">
            <option value="">All Courses</option>
            <% if (courses && courses.length > 0) { %>
              <% courses.forEach(function(c) { %>
                <option value="<%= c.course_id %>" <%= (typeof filters !== 'undefined' && filters.course === c.course_id) ? 'selected' : '' %>>
                  <%= c.acronym %> - <%= c.name %>
                </option>
              <% }); %>
            <% } %>
          </select>
        </div>

        <div class="filter-group">
          <label for="filterStatus" class="filter-label">Status</label>
          <select id="filterStatus" name="status" class="form-select form-select-sm">
            <option value="">All Statuses</option>
            <option value="upcoming" <%= (typeof filters !== 'undefined' && filters.status === 'upcoming') ? 'selected' : '' %>>Upcoming</option>
            <option value="full" <%= (typeof filters !== 'undefined' && filters.status === 'full') ? 'selected' : '' %>>Full</option>
            <option value="completed" <%= (typeof filters !== 'undefined' && filters.status === 'completed') ? 'selected' : '' %>>Completed</option>
            <option value="cancelled" <%= (typeof filters !== 'undefined' && filters.status === 'cancelled') ? 'selected' : '' %>>Cancelled</option>
          </select>
        </div>

        <div class="filter-actions">
          <button type="submit" class="btn btn-secondary">
            <i class="fas fa-filter"></i>
            Filter
          </button>
          <a href="/admin/dates" class="btn btn-ghost">
            <i class="fas fa-times"></i>
            Clear
          </a>
        </div>
      </form>

      <!-- Table -->
      <% if (dates && dates.length > 0) { %>
        <div class="table-card">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Course</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Format</th>
                <th>Location</th>
                <th>Participants</th>
                <th>Status</th>
                <th>Active</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% dates.forEach(function(d) { %>
                <tr>
                  <td>
                    <span class="course-acronym"><%= d.course_acronym || d.course_id %></span>
                  </td>
                  <td><%= d.start_date ? new Date(d.start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—' %></td>
                  <td><%= d.end_date ? new Date(d.end_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—' %></td>
                  <td>
                    <%
                      var formatClass = 'badge-info';
                      if (d.format === 'In-Person') formatClass = 'badge-purple';
                      if (d.format === 'Hybrid') formatClass = 'badge-warning';
                    %>
                    <span class="badge <%= formatClass %>"><%= d.format || '—' %></span>
                  </td>
                  <td><%= d.location || '—' %></td>
                  <td>
                    <span class="participants-count">
                      <%= d.current_participants || 0 %> / <%= d.max_participants || '∞' %>
                    </span>
                  </td>
                  <td>
                    <%
                      var statusClass = 'badge-info';
                      if (d.status === 'upcoming') statusClass = 'badge-success';
                      if (d.status === 'full') statusClass = 'badge-warning';
                      if (d.status === 'completed') statusClass = 'badge-inactive';
                      if (d.status === 'cancelled') statusClass = 'badge-danger';
                    %>
                    <span class="badge <%= statusClass %>"><%= d.status ? d.status.charAt(0).toUpperCase() + d.status.slice(1) : '—' %></span>
                  </td>
                  <td>
                    <% if (d.is_active) { %>
                      <span class="badge badge-success">Yes</span>
                    <% } else { %>
                      <span class="badge badge-inactive">No</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="action-buttons">
                      <a href="/admin/dates/<%= d.id %>/edit" class="btn btn-sm btn-secondary" title="Edit">
                        <i class="fas fa-pencil-alt"></i>
                        Edit
                      </a>
                      <button
                        type="button"
                        class="btn btn-sm btn-danger"
                        data-delete-url="/api/admin/dates/<%= d.id %>"
                        data-confirm="Delete this course date?"
                        title="Delete"
                      >
                        <i class="fas fa-trash"></i>
                        Delete
                      </button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="fas fa-calendar-alt"></i>
          </div>
          <h3 class="empty-state-title">No Course Dates Found</h3>
          <p class="empty-state-text">
            <% if (typeof filters !== 'undefined' && (filters.course || filters.status)) { %>
              No dates match your current filters.
            <% } else { %>
              Schedule your first course date to get started.
            <% } %>
          </p>
          <a href="/admin/dates/new" class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Add New Date
          </a>
        </div>
      <% } %>

    </div><!-- /.admin-content -->
  </div><!-- /.admin-main -->
</div><!-- /.admin-wrapper -->

<%- include('../partials/scripts') %>
