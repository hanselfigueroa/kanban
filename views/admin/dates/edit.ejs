<%- include('../partials/head', { title: (isNew ? 'Add Course Date' : 'Edit Course Date') + ' - Kanban.UNO Admin' }) %>
</head>
<body class="admin-body">
<div class="admin-wrapper">

  <%- include('../partials/sidebar') %>

  <div class="admin-main">
    <%- include('../partials/topbar', { pageTitle: isNew ? 'Add Course Date' : 'Edit Course Date' }) %>

    <div class="admin-content">

      <div class="breadcrumb">
        <a href="/admin/dates" class="breadcrumb-link">Course Dates</a>
        <i class="fas fa-chevron-right breadcrumb-sep"></i>
        <span class="breadcrumb-current"><%= isNew ? 'Add New Date' : 'Edit Date' %></span>
      </div>

      <form
        action="<%= isNew ? '/admin/dates' : '/admin/dates/' + date.id %>"
        method="POST"
        class="edit-form"
      >
        <% if (!isNew) { %>
          <input type="hidden" name="_method" value="PUT">
        <% } %>

        <div class="form-card">
          <div class="form-card-header">
            <h3 class="form-card-title">
              <i class="fas fa-calendar-alt"></i>
              Date Details
            </h3>
          </div>
          <div class="form-card-body">
            <div class="form-grid form-grid-2">

              <!-- Course -->
              <div class="form-group form-group-full">
                <label for="course_id" class="form-label">Course <span class="required">*</span></label>
                <select id="course_id" name="course_id" class="form-select" required>
                  <option value="">Select a course...</option>
                  <% if (courses && courses.length > 0) { %>
                    <% courses.forEach(function(c) { %>
                      <option
                        value="<%= c.course_id %>"
                        data-duration="<%= c.duration %>"
                        <%= (date && date.course_id === c.course_id) ? 'selected' : '' %>
                      >
                        <%= c.acronym %> — <%= c.name %>
                      </option>
                    <% }); %>
                  <% } %>
                </select>
              </div>

              <!-- Start Date -->
              <div class="form-group">
                <label for="start_date" class="form-label">Start Date <span class="required">*</span></label>
                <input
                  type="text"
                  id="start_date"
                  name="start_date"
                  class="form-input"
                  value="<%= date ? date.start_date : '' %>"
                  data-datepicker
                  placeholder="Select start date..."
                  required
                >
              </div>

              <!-- End Date -->
              <div class="form-group">
                <label for="end_date" class="form-label">End Date <span class="required">*</span></label>
                <input
                  type="text"
                  id="end_date"
                  name="end_date"
                  class="form-input"
                  value="<%= date ? date.end_date : '' %>"
                  data-datepicker
                  placeholder="Select end date..."
                  required
                >
                <span class="form-hint" id="durationHint">
                  <i class="fas fa-info-circle"></i>
                  Select a course to see its standard duration.
                </span>
              </div>

              <!-- Format -->
              <div class="form-group">
                <label for="format" class="form-label">Format <span class="required">*</span></label>
                <select id="format" name="format" class="form-select" required>
                  <option value="">Select format...</option>
                  <option value="Live Virtual" <%= (date && date.format === 'Live Virtual') ? 'selected' : '' %>>Live Virtual</option>
                  <option value="In-Person" <%= (date && date.format === 'In-Person') ? 'selected' : '' %>>In-Person</option>
                  <option value="Hybrid" <%= (date && date.format === 'Hybrid') ? 'selected' : '' %>>Hybrid</option>
                </select>
              </div>

              <!-- Location (shown for non-virtual) -->
              <div class="form-group" id="locationGroup">
                <label for="location" class="form-label">Location</label>
                <input
                  type="text"
                  id="location"
                  name="location"
                  class="form-input"
                  value="<%= date ? date.location : '' %>"
                  placeholder="City, Venue or Online platform..."
                >
              </div>

              <!-- Timezone -->
              <div class="form-group">
                <label for="timezone" class="form-label">Timezone</label>
                <select id="timezone" name="timezone" class="form-select">
                  <option value="">Select timezone...</option>
                  <option value="America/New_York" <%= (date && date.timezone === 'America/New_York') ? 'selected' : '' %>>Eastern Time (ET)</option>
                  <option value="America/Chicago" <%= (date && date.timezone === 'America/Chicago') ? 'selected' : '' %>>Central Time (CT)</option>
                  <option value="America/Denver" <%= (date && date.timezone === 'America/Denver') ? 'selected' : '' %>>Mountain Time (MT)</option>
                  <option value="America/Los_Angeles" <%= (date && date.timezone === 'America/Los_Angeles') ? 'selected' : '' %>>Pacific Time (PT)</option>
                  <option value="America/Anchorage" <%= (date && date.timezone === 'America/Anchorage') ? 'selected' : '' %>>Alaska Time (AKT)</option>
                  <option value="Pacific/Honolulu" <%= (date && date.timezone === 'Pacific/Honolulu') ? 'selected' : '' %>>Hawaii Time (HT)</option>
                  <option value="Europe/London" <%= (date && date.timezone === 'Europe/London') ? 'selected' : '' %>>London (GMT/BST)</option>
                  <option value="Europe/Paris" <%= (date && date.timezone === 'Europe/Paris') ? 'selected' : '' %>>Central European (CET)</option>
                  <option value="Asia/Dubai" <%= (date && date.timezone === 'Asia/Dubai') ? 'selected' : '' %>>Dubai (GST)</option>
                  <option value="Asia/Singapore" <%= (date && date.timezone === 'Asia/Singapore') ? 'selected' : '' %>>Singapore (SGT)</option>
                  <option value="Australia/Sydney" <%= (date && date.timezone === 'Australia/Sydney') ? 'selected' : '' %>>Sydney (AEST)</option>
                  <option value="UTC" <%= (date && date.timezone === 'UTC') ? 'selected' : '' %>>UTC</option>
                </select>
              </div>

              <!-- Max Participants -->
              <div class="form-group">
                <label for="max_participants" class="form-label">Max Participants</label>
                <input
                  type="number"
                  id="max_participants"
                  name="max_participants"
                  class="form-input"
                  value="<%= date ? date.max_participants : '' %>"
                  placeholder="Leave blank for unlimited"
                  min="1"
                >
              </div>

              <!-- Status -->
              <div class="form-group">
                <label for="status" class="form-label">Status</label>
                <select id="status" name="status" class="form-select">
                  <option value="upcoming" <%= (!date || date.status === 'upcoming') ? 'selected' : '' %>>Upcoming</option>
                  <option value="full" <%= (date && date.status === 'full') ? 'selected' : '' %>>Full</option>
                  <option value="completed" <%= (date && date.status === 'completed') ? 'selected' : '' %>>Completed</option>
                  <option value="cancelled" <%= (date && date.status === 'cancelled') ? 'selected' : '' %>>Cancelled</option>
                </select>
              </div>

              <!-- Display Order -->
              <div class="form-group">
                <label for="display_order" class="form-label">Display Order</label>
                <input
                  type="number"
                  id="display_order"
                  name="display_order"
                  class="form-input"
                  value="<%= date ? date.display_order : 0 %>"
                  min="0"
                >
              </div>

              <!-- Notes -->
              <div class="form-group form-group-full">
                <label for="notes" class="form-label">Notes</label>
                <textarea
                  id="notes"
                  name="notes"
                  class="form-textarea"
                  rows="4"
                  placeholder="Internal notes about this date..."
                ><%= date ? date.notes : '' %></textarea>
              </div>

              <!-- Is Active -->
              <div class="form-group form-group-checkbox">
                <label class="checkbox-label">
                  <input
                    type="checkbox"
                    name="is_active"
                    value="1"
                    class="form-checkbox"
                    <%= (date && date.is_active) ? 'checked' : (!date ? 'checked' : '') %>
                  >
                  <span class="checkbox-text">Active (show on site)</span>
                </label>
              </div>

            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i>
            Save Changes
          </button>
          <a href="/admin/dates" class="btn btn-secondary">
            <i class="fas fa-times"></i>
            Cancel
          </a>
        </div>

      </form>

    </div><!-- /.admin-content -->
  </div><!-- /.admin-main -->
</div><!-- /.admin-wrapper -->

<script>
  (function() {
    var formatSelect = document.getElementById('format');
    var locationGroup = document.getElementById('locationGroup');
    var courseSelect = document.getElementById('course_id');
    var durationHint = document.getElementById('durationHint');

    function toggleLocationField() {
      var val = formatSelect.value;
      locationGroup.style.display = (val === 'Live Virtual') ? 'none' : '';
    }

    function updateDurationHint() {
      var selected = courseSelect.options[courseSelect.selectedIndex];
      var dur = selected ? selected.getAttribute('data-duration') : '';
      if (dur) {
        durationHint.innerHTML = '<i class="fas fa-info-circle"></i> This course typically runs ' + dur + '.';
      } else {
        durationHint.innerHTML = '<i class="fas fa-info-circle"></i> Select a course to see its standard duration.';
      }
    }

    formatSelect.addEventListener('change', toggleLocationField);
    courseSelect.addEventListener('change', updateDurationHint);

    toggleLocationField();
    updateDurationHint();
  })();
</script>

<%- include('../partials/scripts') %>
