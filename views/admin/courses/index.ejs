<%- include('../partials/head', { title: 'Courses - Kanban.UNO Admin' }) %>
</head>
<body class="admin-body">
<div class="admin-wrapper">

  <%- include('../partials/sidebar') %>

  <div class="admin-main">
    <%- include('../partials/topbar', { pageTitle: 'Courses' }) %>

    <div class="admin-content">

      <div class="content-header">
        <h2 class="content-title">Courses</h2>
        <a href="/admin/courses/new" class="btn btn-primary">
          <i class="fas fa-plus"></i>
          Add New Course
        </a>
      </div>

      <% if (req.query.success === 'deleted') { %>
        <div class="alert alert-success"><i class="fas fa-check-circle"></i> Course deleted successfully.</div>
      <% } %>
      <% if (req.query.error === 'delete_failed') { %>
        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> Failed to delete course.</div>
      <% } %>

      <% if (courses && courses.length > 0) { %>
        <div class="table-card">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Acronym</th>
                <th>Name</th>
                <th>Level</th>
                <th>Duration</th>
                <th>Price</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% courses.forEach(function(course) { %>
                <tr>
                  <td>
                    <span class="course-acronym"><%= course.acronym %></span>
                  </td>
                  <td class="course-name"><%= course.name %></td>
                  <td><%= course.level %></td>
                  <td><%= course.duration %></td>
                  <td><%= course.price ? 'Q' + parseFloat(course.price).toFixed(2) : '—' %></td>
                  <td>
                    <% if (course.is_active) { %>
                      <span class="badge badge-success">Active</span>
                    <% } else { %>
                      <span class="badge badge-inactive">Inactive</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="action-buttons">
                      <a href="/admin/courses/<%= course.course_id %>/edit" class="btn btn-sm btn-secondary" title="Edit">
                        <i class="fas fa-pencil-alt"></i>
                        Edit
                      </a>
                      <a href="/admin/dates?course=<%= course.course_id %>" class="btn btn-sm btn-secondary" title="Dates">
                        <i class="fas fa-calendar-alt"></i>
                        Dates
                      </a>
                      <a href="/admin/courses/<%= course.course_id %>/curriculum" class="btn btn-sm btn-secondary" title="Curriculum">
                        <i class="fas fa-list-ul"></i>
                        Curriculum
                      </a>
                      <button
                        class="btn btn-sm <%= course.is_active ? 'btn-warning' : 'btn-success' %>"
                        data-toggle-active
                        data-course-id="<%= course.course_id %>"
                        title="<%= course.is_active ? 'Deactivate' : 'Activate' %>"
                      >
                        <i class="fas <%= course.is_active ? 'fa-toggle-off' : 'fa-toggle-on' %>"></i>
                        <%= course.is_active ? 'Deactivate' : 'Activate' %>
                      </button>
                      <button
                        class="btn btn-sm btn-danger"
                        data-delete-course
                        data-course-id="<%= course.course_id %>"
                        data-course-name="<%= course.name %>"
                        title="Delete"
                      >
                        <i class="fas fa-trash-alt"></i>
                        Delete
                      </button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="fas fa-book-open"></i>
          </div>
          <h3 class="empty-state-title">No Courses Found</h3>
          <p class="empty-state-text">Get started by adding your first course.</p>
          <a href="/admin/courses/new" class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Add New Course
          </a>
        </div>
      <% } %>

    </div><!-- /.admin-content -->
  </div><!-- /.admin-main -->
</div><!-- /.admin-wrapper -->

<%- include('../partials/scripts') %>

<script>
(function () {
  // ── Toggle Active / Deactivate ─────────────────────────────────────────────
  document.querySelectorAll('[data-toggle-active]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id = btn.getAttribute('data-course-id');
      var isActive = btn.title === 'Deactivate';
      var label = isActive ? 'Deactivating…' : 'Activating…';
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> ' + label;

      fetch('/admin/api/courses/' + id + '/toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.success) {
            // Reload page to reflect new state
            window.location.reload();
          } else {
            alert('Failed to update course status.');
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-toggle-off"></i> ' + (isActive ? 'Deactivate' : 'Activate');
          }
        })
        .catch(function () {
          alert('Network error. Please try again.');
          btn.disabled = false;
          btn.innerHTML = '<i class="fas fa-toggle-off"></i> ' + (isActive ? 'Deactivate' : 'Activate');
        });
    });
  });
})();

  // ── Delete Course ──────────────────────────────────────────────────────────
  document.querySelectorAll('[data-delete-course]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var id   = btn.getAttribute('data-course-id');
      var name = btn.getAttribute('data-course-name');
      if (!confirm('Delete "' + name + '"? This cannot be undone.')) return;
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Deleting…';

      var form = document.createElement('form');
      form.method = 'POST';
      form.action = '/admin/courses/' + id + '/delete';
      document.body.appendChild(form);
      form.submit();
    });
  });
</script>
