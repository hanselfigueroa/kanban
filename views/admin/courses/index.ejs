<%- include('../partials/head', { title: 'Courses - Kanban.UNO Admin' }) %>
</head>
<body>
<div class="admin-wrapper">

  <%- include('../partials/sidebar') %>

  <div class="admin-main">
    <%- include('../partials/topbar', { pageTitle: 'Courses' }) %>

    <div class="admin-content">

      <div class="content-header">
        <h2 class="content-title">Courses</h2>
        <a href="/admin/courses/new" class="btn btn-primary">
          <i class="fas fa-plus"></i>
          Add New Course
        </a>
      </div>

      <% if (courses && courses.length > 0) { %>
        <div class="table-card">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Acronym</th>
                <th>Name</th>
                <th>Level</th>
                <th>Duration</th>
                <th>Status</th>
                <th>Order</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% courses.forEach(function(course) { %>
                <tr>
                  <td>
                    <span class="course-acronym"><%= course.acronym %></span>
                  </td>
                  <td class="course-name"><%= course.name %></td>
                  <td><%= course.level %></td>
                  <td><%= course.duration %></td>
                  <td>
                    <% if (course.is_active) { %>
                      <span class="badge badge-success">Active</span>
                    <% } else { %>
                      <span class="badge badge-inactive">Inactive</span>
                    <% } %>
                  </td>
                  <td><%= course.display_order %></td>
                  <td>
                    <div class="action-buttons">
                      <a href="/admin/courses/<%= course.course_id %>/edit" class="btn btn-sm btn-secondary" title="Edit">
                        <i class="fas fa-pencil-alt"></i>
                        Edit
                      </a>
                      <a href="/admin/dates?course=<%= course.course_id %>" class="btn btn-sm btn-secondary" title="Dates">
                        <i class="fas fa-calendar-alt"></i>
                        Dates
                      </a>
                      <a href="/admin/courses/<%= course.course_id %>/curriculum" class="btn btn-sm btn-secondary" title="Curriculum">
                        <i class="fas fa-list-ul"></i>
                        Curriculum
                      </a>
                      <button
                        class="btn btn-sm <%= course.is_active ? 'btn-warning' : 'btn-success' %>"
                        data-toggle-active
                        data-course-id="<%= course.course_id %>"
                        title="<%= course.is_active ? 'Deactivate' : 'Activate' %>"
                      >
                        <i class="fas <%= course.is_active ? 'fa-toggle-off' : 'fa-toggle-on' %>"></i>
                        <%= course.is_active ? 'Deactivate' : 'Activate' %>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">
            <i class="fas fa-book-open"></i>
          </div>
          <h3 class="empty-state-title">No Courses Found</h3>
          <p class="empty-state-text">Get started by adding your first course.</p>
          <a href="/admin/courses/new" class="btn btn-primary">
            <i class="fas fa-plus"></i>
            Add New Course
          </a>
        </div>
      <% } %>

    </div><!-- /.admin-content -->
  </div><!-- /.admin-main -->
</div><!-- /.admin-wrapper -->

<%- include('../partials/scripts') %>
