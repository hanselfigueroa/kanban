<%- include('partials/header') %>
<%- include('partials/nav') %>

<section class="page-hero">
  <div class="container">
    <span class="section-badge">Strategic Authority</span>
    <% if (content && content.about_headline) { %>
    <h1 class="page-hero-title"><%= content.about_headline %></h1>
    <% } else { %>
    <h1 class="page-hero-title">Transforming the future of <span class="text-gradient">workflow education.</span></h1>
    <% } %>
    <p class="page-hero-subtitle"><%= (content && content.about_mission) || 'Kanban.UNO is the premier destination for Kanban University accredited training. We deliver world-class education that transforms how organizations deliver value.' %></p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="about-grid">
      <div class="about-content fade-in">
        <h2>Our Mission</h2>
        <p>We are dedicated to spreading the knowledge and practice of the Kanban Method to organizations worldwide. As an accredited Kanban University training provider, we deliver world-class education that transforms how teams and organizations deliver value.</p>
        <p>Our trainers are Accredited Kanban Trainers (AKTs) with extensive experience implementing Kanban in diverse industries including technology, finance, healthcare, and government.</p>
      </div>
      <div class="about-values fade-in">
        <div class="value-card">
          <div class="value-icon"><i class="fas fa-eye"></i></div>
          <h3>Transparency</h3>
          <p>We believe in making work visible, sharing knowledge openly, and building trust through clarity.</p>
        </div>
        <div class="value-card">
          <div class="value-icon"><i class="fas fa-sync-alt"></i></div>
          <h3>Continuous Improvement</h3>
          <p>We practice what we teach - constantly evolving our curriculum and methods based on feedback.</p>
        </div>
        <div class="value-card">
          <div class="value-icon"><i class="fas fa-users"></i></div>
          <h3>Community</h3>
          <p>Our graduates join a global community of Kanban practitioners dedicated to better ways of working.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section section-dark">
  <div class="container">
    <div class="section-header fade-in">
      <h2 class="section-title">By the <span class="text-gradient">Numbers</span></h2>
    </div>
    <div class="stats-grid">
      <div class="stat-card fade-in">
        <span class="stat-card-number">500+</span>
        <span class="stat-card-label">Certified Graduates</span>
      </div>
      <div class="stat-card fade-in">
        <span class="stat-card-number">50+</span>
        <span class="stat-card-label">Organizations Served</span>
      </div>
      <div class="stat-card fade-in">
        <span class="stat-card-number">10+</span>
        <span class="stat-card-label">Years of Experience</span>
      </div>
      <div class="stat-card fade-in">
        <span class="stat-card-number">98%</span>
        <span class="stat-card-label">Satisfaction Rate</span>
      </div>
    </div>
  </div>
</section>

<section class="section cta-section">
  <div class="container">
    <div class="cta-content fade-in">
      <h2>Ready to Start Your Kanban Journey?</h2>
      <p>Browse our courses and find the perfect fit for your learning goals.</p>
      <a href="/courses" class="btn btn-primary btn-lg">View Courses <i class="fas fa-arrow-right"></i></a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
