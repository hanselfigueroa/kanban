<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<section class="checkout-page">
  <div class="checkout-container">

    <div class="checkout-header">
      <h1 class="checkout-title">Checkout</h1>
      <p class="checkout-subtitle">Complete your enrollment for <strong><%= course ? course.name : 'Course' %></strong></p>
    </div>

    <div class="checkout-grid">

      <!-- Left: Order Summary -->
      <div class="checkout-summary">
        <div class="checkout-card">
          <div class="checkout-card-header">
            <h2>Order Summary</h2>
          </div>
          <div class="checkout-card-body">

            <div class="order-item">
              <div class="order-item-info">
                <span class="order-item-badge"><%= course ? course.acronym : '' %></span>
                <div>
                  <h3 class="order-item-name"><%= course ? course.name : 'Course' %></h3>
                  <% if (courseDate) { %>
                    <p class="order-item-date">
                      <i class="fas fa-calendar-alt"></i>
                      <%= new Date(courseDate.start_date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                    </p>
                    <% if (courseDate.format) { %>
                      <p class="order-item-format">
                        <i class="fas fa-<%= courseDate.format.toLowerCase().includes('virtual') ? 'video' : 'building' %>"></i>
                        <%= courseDate.format %><%= courseDate.location ? ' — ' + courseDate.location : '' %>
                      </p>
                    <% } %>
                  <% } %>
                </div>
              </div>
            </div>

            <div class="order-divider"></div>

            <div class="order-pricing">
              <div class="price-row">
                <span>Subtotal</span>
                <span><%= pricing.currency %> <%= pricing.subtotal.toFixed(2) %></span>
              </div>
              <% if (pricing.taxRate > 0) { %>
                <div class="price-row">
                  <span>IVA (<%= (pricing.taxRate * 100).toFixed(0) %>%)</span>
                  <span><%= pricing.currency %> <%= pricing.taxAmount.toFixed(2) %></span>
                </div>
              <% } %>
              <div class="price-row price-total">
                <span>Total</span>
                <span><%= pricing.currency %> <%= pricing.total.toFixed(2) %></span>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Right: Customer Info + Payment -->
      <div class="checkout-payment">
        <div class="checkout-card">
          <div class="checkout-card-header">
            <h2>Your Details</h2>
          </div>
          <div class="checkout-card-body">

            <form id="checkoutForm">
              <input type="hidden" name="course_date_id" value="<%= courseDate ? courseDate.id : '' %>">

              <div class="checkout-field">
                <label for="co_full_name">Full Name <span class="required">*</span></label>
                <input type="text" id="co_full_name" name="full_name" class="checkout-input" placeholder="John Doe" required>
              </div>

              <div class="checkout-field">
                <label for="co_email">Email Address <span class="required">*</span></label>
                <input type="email" id="co_email" name="email" class="checkout-input" placeholder="john@company.com" required>
              </div>

              <div class="checkout-field">
                <label for="co_phone">Phone Number</label>
                <input type="tel" id="co_phone" name="phone" class="checkout-input" placeholder="+502 1234 5678">
              </div>

              <div class="checkout-field">
                <label for="co_company">Company</label>
                <input type="text" id="co_company" name="company" class="checkout-input" placeholder="Your Company">
              </div>

              <div id="payment-section" style="margin-top:1.5rem;">
                <% if (pricing.total <= 0) { %>
                  <div class="checkout-notice">
                    <i class="fas fa-info-circle"></i>
                    <p>No payment is required. Click below to confirm your enrollment.</p>
                  </div>
                  <button type="submit" class="btn-checkout" id="btnPay">
                    <i class="fas fa-check-circle"></i>
                    Confirm Enrollment
                  </button>
                <% } else { %>
                  <div class="checkout-notice checkout-notice-info">
                    <i class="fas fa-credit-card"></i>
                    <div>
                      <p><strong>Secure online payment</strong></p>
                      <p>You will be redirected to Paggo to complete your payment of <strong><%= pricing.currency %> <%= pricing.total.toFixed(2) %></strong>.</p>
                    </div>
                  </div>

                  <button type="submit" class="btn-checkout" id="btnPay">
                    <i class="fas fa-lock"></i>
                    Pay <%= pricing.currency %> <%= pricing.total.toFixed(2) %>
                  </button>

                  <div id="payment-processing" style="display:none;" class="checkout-processing">
                    <div class="spinner"></div>
                    <p>Processing...</p>
                  </div>

                  <div id="payment-result" style="display:none;"></div>
                <% } %>
              </div>

              <% if (settings.checkout_terms) { %>
                <div class="checkout-terms">
                  <p><%= settings.checkout_terms %></p>
                </div>
              <% } %>
            </form>

          </div>
        </div>

        <a href="/courses/<%= course ? (course.course_id || course.id) : '' %>" class="checkout-back">
          <i class="fas fa-arrow-left"></i> Back to course
        </a>
      </div>

    </div>
  </div>
</section>

<script>
(function () {
  var form    = document.getElementById('checkoutForm');
  var payBtn  = document.getElementById('btnPay');
  var courseId = '<%= course ? (course.id || course.course_id) : "" %>';

  if (!form || !payBtn) return;

  form.addEventListener('submit', function (e) {
    e.preventDefault();

    var fullName = form.querySelector('[name="full_name"]').value.trim();
    var email    = form.querySelector('[name="email"]').value.trim();
    if (!fullName || !email) {
      alert('Please fill in your name and email.');
      return;
    }

    payBtn.disabled = true;
    payBtn.style.opacity = '0.7';
    var processing = document.getElementById('payment-processing');
    if (processing) processing.style.display = 'flex';

    var formData = new FormData(form);
    var data = Object.fromEntries(formData.entries());

    fetch('/checkout/' + courseId + '/pay', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success && (data.payment_url || data.redirect_url)) {
          window.location.href = data.payment_url || data.redirect_url;
        } else {
          if (processing) processing.style.display = 'none';
          payBtn.disabled = false;
          payBtn.style.opacity = '';
          alert('Error: ' + (data.error || 'Something went wrong. Please try again.'));
        }
      })
      .catch(function () {
        if (processing) processing.style.display = 'none';
        payBtn.disabled = false;
        payBtn.style.opacity = '';
        alert('Network error. Please try again.');
      });
  });
})();
</script>

<%- include('../partials/footer') %>
